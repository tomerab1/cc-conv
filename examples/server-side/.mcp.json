{
  "mcpServers": {
    "bridge": {
      "command": "cc-bridge",
      "env": {
        "SELF_NAME": "server",
        "PEER_NAME": "native",
        "SELF_PORT": "8801",
        "PEER_URL": "http://127.0.0.1:8802/"
      }
    },
    "telegram": {
      "command": "cc-bridge-telegram",
      "env": {
        "AGENT_NAME": "server",
        "ALLOWED_USER_ID": "REPLACE_WITH_YOUR_TELEGRAM_USER_ID",
        "TELEGRAM_CHAT_ID": "REPLACE_WITH_GROUP_CHAT_ID_OR_OMIT_TO_DISABLE_RELAY"
      }
    }
  }
}
